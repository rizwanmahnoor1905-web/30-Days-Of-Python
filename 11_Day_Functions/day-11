def sum_of_odd_num(num):
        sums=0
        for nums in range(num):
            if nums%2!=0:
                sums+=nums
        return sums
print(sum_of_odd_num(9))
def sum_of_even_num(num):
        sums=0
        for nums in range(num):
            if nums%2==0:
                sums+=nums
        return sums
