def even_odds(num):
    count_odd = 0
    count_even = 0

    for nums in range(num):
        if nums % 2 != 0:
            count_odd += 1
        else:
            count_even += 1

    return count_even, count_odd

even, odd = even_odds(78)

print(f"Number of even numbers: {even}")
print(f"Number of odd numbers: {odd}")
def factorial(num):
    fact=1
    for nums in range(1,num+1):
        fact*=nums
    return fact
print(factorial(5))
